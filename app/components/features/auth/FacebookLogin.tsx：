"use client";
import React from 'react';

declare global {
  interface Window {
    FB: any;
    fbAsyncInit: () => void;
  }
}

export const FacebookLogin: React.FC<{ onLogin: (token: string) => void }> = ({ onLogin }) => {
  const [isLoading, setIsLoading] = React.useState(false);

  React.useEffect(() => {
    // 載入 Facebook SDK
    window.fbAsyncInit = function() {
      window.FB.init({
        appId: process.env.NEXT_PUBLIC_FB_APP_ID,
        cookie: true,
        xfbml: true,
        version: 'v19.0'
      });
    };

    const script = document.createElement('script');
    script.src = 'https://connect.facebook.net/en_US/sdk.js';
    script.async = true;
    script.defer = true;
    document.body.appendChild(script);
  }, []);

  const handleLogin = () => {
    setIsLoading(true);
    window.FB.login((response: any) => {
      if (response.authResponse) {
        const token = response.authResponse.accessToken;
        localStorage.setItem('fb_access_token', token);
        onLogin(token);
      }
      setIsLoading(false);
    }, { scope: 'public_profile,email,publish_to_groups' }); // 注意：publish_to_groups 需要審核
  };

  return (
    <button
      onClick={handleLogin}
      disabled={isLoading}
      style={{
        backgroundColor: '#1877F2',
        color: 'white',
        padding: '10px 16px',
        borderRadius: '8px',
        border: 'none',
        cursor: 'pointer',
      }}
    >
      {isLoading ? 'Loading...' : 'Login with Facebook'}
    </button>
  );
};